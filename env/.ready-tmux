#!/usr/bin/env bash

tmux rename-window cli

tmux neww -n dev
tmux send-keys "nvim" C-m

tmux neww -n ai
tmux send-keys "claude" C-m

tmux neww -n server

tmux select-window -t cli

# Open Obsidian file in new window
# tmux send-keys 'obsidian vault="Vault" open file="File Name" newtab && obsidian command id=workspace:open-in-new-window' C-m

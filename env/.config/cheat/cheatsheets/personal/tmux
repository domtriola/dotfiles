# NOTE: The default prefix is Ctrl-b, but I've remapped it to Ctrl-a

# List all keybindings
Ctrl-a ?

# List sessions
tmux ls

# View windows
Ctrl-a w

# Enter tmux copy mode
Ctrl-a [

# To create a new session from within tmux, spawn as a detached session
tmux new-session -d

# Create a new window
tmux neww -n name

# To detach from tmux
Ctrl-a d

# To close a tmux window (from the window to close):
exit

# To close a session:
tmux kill-session -t <session-name>

# To attach to session (from outside tmux)
tmux attach-session -t name

# To attach to session (from another session)
tmux switch-client -t name

# TIP: has-session uses prefix search with `-t name`, but searches for exact match with `-t=name`
tmux has-session -t=name

# Move to named session:window
tmux switch-client -t sname:wname

#!/usr/bin/env bash

# Add directories here to include them in session discovery.
search_roots=(
  "$HOME/src/personal"
  "$HOME/src/community"
  "$HOME/src/work"
  "$HOME/src/work/static-sites"
)

# Find a potential tmux session for a specified directory
if [[ -n "${1:-}" ]]; then
  selected_dir="$1"
else
  selected_dir=$(find "${search_roots[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi
if [[ -z "$selected_dir" ]]; then
  exit 0
fi

# Convert the selected directory name into a valid tmux session name by
# replacing problematic characters
session_name=$(basename "$selected_dir" | tr ":,. " "____")

switch_to() {
  if [[ -z "$TMUX" ]]; then
    tmux attach-session -t "$session_name"
  else
    tmux switch-client -t "$session_name"
  fi
}

if tmux has-session -t "$session_name" 2>/dev/null; then
  switch_to
  exit 0
fi

tmux new-session -ds "$session_name" -c "$selected_dir"
switch_to

# Send ready command to the new tmux session (rather than having it execute in
# source location)
tmux send-keys -t "$session_name" "ready-tmux" ^M

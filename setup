#!/usr/bin/env bash
#
# Usage: ./setup [<pattern>] [--dry]
#
# Discovers and executes platform-appropriate scripts under ./setups/.
#
# Execution order:
#   1. setups/shared/         (cross-platform installers, all OSes)
#   2. setups/macos/          (macOS only)
#      - or -
#      setups/linux/common/   (any Linux)
#      setups/linux/<distro>/ (Fedora, Ubuntu, ...)
#
# Within each directory, scripts run in filename order. Use numeric
# prefixes (00_, 10_, 20_) to control ordering.
#
# Arguments:
#   <pattern>  A grep pattern. Only scripts whose path matches <pattern> are run.
#              If omitted, all scripts are run.
#   --dry      Print what would be executed without running anything.
#
# Examples:
#   ./setup                   # run all platform-appropriate scripts
#   ./setup packages          # run only scripts matching "packages"
#   ./setup packages --dry    # preview which scripts would run

set -eo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
source "$script_dir/setups/lib/platform.sh"

filter=""
dry="0"

while [[ $# -gt 0 ]]; do
  if [[ $1 == "--dry" ]]; then
    dry="1"
  else
    filter="$1"
  fi
  shift
done

log() {
  if [[ $dry == "1" ]]; then
    echo "[DRY RUN]: $@"
  else
    echo "$@"
  fi
}

execute() {
  log "Execute $@"
  if [[ $dry == "1" ]]; then
    return
  fi

  "$@"
}

run_script() {
  local script="$1"
  if [[ -n "$filter" ]] && ! echo "$script" | grep -q "$filter"; then
    log "Skipping $script"
    return
  fi
  execute "$script"
}

run_dir() {
  local dir="$1"
  local -a scripts
  local script
  [[ -d "$dir" ]] || return 0
  log "--- $dir ---"

  mapfile -t scripts < <(find "$dir" -maxdepth 1 -mindepth 1 -type f | sort)
  for script in "${scripts[@]}"; do
    [[ -f "$script" && -x "$script" ]] || continue
    run_script "$script"
  done
}

log "$script_dir -- $filter"

cd "$script_dir"

run_dir "$script_dir/setups/shared"

if is_mac; then
  run_dir "$script_dir/setups/macos"
elif is_linux; then
  run_dir "$script_dir/setups/linux/common"
  if is_fedora; then
    run_dir "$script_dir/setups/linux/fedora"
  elif is_ubuntu; then
    run_dir "$script_dir/setups/linux/ubuntu"
  fi
fi

echo "----------------------------------------"
echo "All scripts executed"
